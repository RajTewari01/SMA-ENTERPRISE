# ========================================================================
# Social Automation Agent - .gitignore
# Protects: Models, user data, secrets,downloads,venvs,etc.
# =======================================================================

# =======================================================================
# 1. VIRTUAL ENVIRONMENTS (ALL of them)
# =======================================================================
/venvs
/.venv
/env
# =======================================================================
# 2. CONFIGS =======================================================================
*.env
*.env.local
.env
.env.*
!*.env.example
!config.env
# =======================================================================
# 2. PYTHON
# =======================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/

# ============================================================================
# 3. Ruff cache
# ============================================================================
.ruff_cache/
.ruff_cache

# ============================================================================
# 4. UV
# ============================================================================
uv.lock